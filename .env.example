# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Push Notifications (generate with: npx web-push generate-vapid-keys)
NUXT_PUBLIC_PUSH_VAPID_PUBLIC_KEY=your_public_vapid_key
NUXT_PUSH_VAPID_PRIVATE_KEY=your_private_vapid_key

# Mapbox (get token at https://account.mapbox.com)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# Google Maps (get API key at https://console.cloud.google.com)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
